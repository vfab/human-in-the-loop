location                 = "westeurope"
resource_group_name      = "rg-vfab"
shared_remote_state_enabled = false
shared_remote_state_path    = "/home/vfabro/src/rg-vfab-terraform/shared/terraform.tfstate"
acr_name                 = "ca81b3cb0669acr"
container_env_name       = "vfab-container-env"
backend_name             = "vfab-hitl-backend"
frontend_name            = "vfab-hitl-frontend"
container_image          = "ca81b3cb0669acr.azurecr.io/hitl-email-assistant:latest"

# Preferred: Foundry-style inputs (OpenAI-compatible endpoint/deployment)
foundry_openai_endpoint    = "https://<your-foundry-openai-resource>.openai.azure.com/"
foundry_openai_deployment  = "gpt-4o"
foundry_openai_api_version = "2024-12-01-preview"

# Preferred key source: Key Vault
key_vault_name             = "<your-key-vault-name>"
openai_api_key_secret_name = "azure-openai-api-key"

# Direct key fallback (optional)
foundry_openai_api_key     = null

# Legacy compatibility inputs (optional; ignored when foundry_* values are set)
azure_openai_endpoint    = null
azure_openai_chat_model  = null
azure_openai_api_version = null
azure_openai_api_key     = null

acs_name                 = "vfab-hitl-acs"
acs_email_service_name   = "vfab-hitl-email"
acs_email_sender_address = "DoNotReply@<your-acs-managed-domain>"
acs_data_location        = "Europe"
